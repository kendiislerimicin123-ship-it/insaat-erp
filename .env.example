# ════════════════════════════════════════════════════════════
# İnşaat ERP - Environment Variables (ÖRNEK)
# Kopyala: cp .env.example .env
# Kendi değerlerinle doldur
# ════════════════════════════════════════════════════════════

NODE_ENV=development

# ─────────────────────────────────
# PostgreSQL
# ─────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=insaat_erp_dev

DATABASE_URL="postgresql://your_db_user:your_strong_password_here@localhost:5432/insaat_erp_dev?schema=public"

# ─────────────────────────────────
# pgAdmin
# ─────────────────────────────────
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password

# ─────────────────────────────────
# JWT (Authentication)
# ─────────────────────────────────
# Üretim: en az 64 karakter random string
JWT_SECRET=replace_with_random_64_char_string_here
JWT_REFRESH_SECRET=replace_with_different_random_64_char_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────
# API
# ─────────────────────────────────
API_PORT=3001
API_HOST=localhost
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────
# Frontend
# ─────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001