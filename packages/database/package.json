{
  "name": "@insaat-erp/database",
  "version": "0.1.0",
  "private": true,
  "description": "İnşaat ERP - Prisma şema ve veritabanı paketi",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "db:format": "prisma format",
    "db:validate": "dotenv -e ../../.env -- prisma validate",
    "db:pull": "dotenv -e ../../.env -- prisma db pull",
    "lint": "echo \"No linter configured for database package yet\"",
    "clean": "rm -rf node_modules .turbo"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  }
}
