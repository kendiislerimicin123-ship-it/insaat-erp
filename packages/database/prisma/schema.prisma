// ════════════════════════════════════════════════════════════
// İnşaat ERP - Prisma Schema
// ════════════════════════════════════════════════════════════
// Bu dosya veri modelinin TEK kaynağıdır.
// Değişiklik sonrası: npm run db:migrate çalıştır
// ════════════════════════════════════════════════════════════

// ─────────────────────────────────
// Generator: Prisma Client (TS API)
// ─────────────────────────────────
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

// ─────────────────────────────────
// Datasource: PostgreSQL
// ─────────────────────────────────
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════
// ENUM'LAR
// ════════════════════════════════════════════════════════════

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION

  @@map("user_status")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  TRIAL
  EXPIRED
  SUSPENDED

  @@map("tenant_status")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  PASSWORD_RESET
  PERMISSION_GRANT
  PERMISSION_REVOKE
  ROLE_ASSIGN
  ROLE_REVOKE

  @@map("audit_action")
}

// ════════════════════════════════════════════════════════════
// MODEL: Tenant (Firma / Şirket)
// ════════════════════════════════════════════════════════════
// Multi-tenant mimarinin temeli. Her veri bir tenant'a aittir.
// ════════════════════════════════════════════════════════════
model Tenant {
  id        String       @id @default(cuid())
  name      String       @db.VarChar(255)
  slug      String       @unique @db.VarChar(100)
  taxNumber String?      @unique @map("tax_number") @db.VarChar(20)
  email     String?      @db.VarChar(255)
  phone     String?      @db.VarChar(20)
  address   String?      @db.Text
  city      String?      @db.VarChar(100)
  status    TenantStatus @default(TRIAL)

  // İlişkiler
  users                  User[]
  roles                  Role[]
  auditLogs              AuditLog[]
  projects               Project[]
  subcontractors         Subcontractor[]
  progressPayments       ProgressPayment[]
  materials              Material[]
  materialMovements      MaterialMovement[]
  contacts               Contact[]
  contactTransactions    ContactTransaction[]
  cheques                Cheque[]
  subcontractorEmployees SubcontractorEmployee[] // ← BU YENİ
  timesheetEntries       TimesheetEntry[] // ← BU YENİ
  timesheetEntryDetails  TimesheetEntryDetail[] // ← BU YENİ

  // Audit alanları
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("tenants")
}

// ════════════════════════════════════════════════════════════
// MODEL: User (Kullanıcı)
// ════════════════════════════════════════════════════════════
model User {
  id              String     @id @default(cuid())
  tenantId        String     @map("tenant_id")
  email           String     @db.VarChar(255)
  password        String     @db.VarChar(255) // bcrypt hash
  firstName       String     @map("first_name") @db.VarChar(100)
  lastName        String     @map("last_name") @db.VarChar(100)
  phone           String?    @db.VarChar(20)
  avatar          String?    @db.Text
  status          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  lastLoginIp     String?    @map("last_login_ip") @db.VarChar(45)

  // İlişkiler
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  // Audit alanları
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  // Multi-tenant: Aynı email birden fazla tenant'ta olabilir
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

// ════════════════════════════════════════════════════════════
// MODEL: Role (Rol)
// ════════════════════════════════════════════════════════════
// Sistem genelinde tanımlı roller. Her tenant kendi rollerini
// kullanabilir veya sistem genel rollerini paylaşabilir.
// ════════════════════════════════════════════════════════════
model Role {
  id          String  @id @default(cuid())
  tenantId    String? @map("tenant_id") // null = sistem geneli
  name        String  @db.VarChar(100)
  slug        String  @db.VarChar(100)
  description String? @db.Text
  isSystem    Boolean @default(false) @map("is_system")

  // İlişkiler
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  // Audit alanları
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([slug])
  @@index([deletedAt])
  @@map("roles")
}

// ════════════════════════════════════════════════════════════
// MODEL: Permission (İzin)
// ════════════════════════════════════════════════════════════
// Sistem genelindeki izinler. Format: resource.action
// Örnek: user.create, project.delete, hakedis.approve
// ════════════════════════════════════════════════════════════
model Permission {
  id          String  @id @default(cuid())
  resource    String  @db.VarChar(100) // user, project, hakedis
  action      String  @db.VarChar(50) // create, read, update, delete
  description String? @db.Text

  // İlişkiler
  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

// ════════════════════════════════════════════════════════════
// MODEL: UserRole (M2M: User <-> Role)
// ════════════════════════════════════════════════════════════
model UserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ════════════════════════════════════════════════════════════
// MODEL: RolePermission (M2M: Role <-> Permission)
// ════════════════════════════════════════════════════════════
model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  grantedAt    DateTime @default(now()) @map("granted_at")
  grantedBy    String?  @map("granted_by")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ════════════════════════════════════════════════════════════
// MODEL: RefreshToken (JWT Refresh Token Yönetimi)
// ════════════════════════════════════════════════════════════
// Refresh token'lar DB'de saklanır → iptal edilebilir.
// Çalınan token'lar bu tablodan silinerek iptal edilebilir.
// ════════════════════════════════════════════════════════════
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique @db.VarChar(500)
  userAgent String?   @map("user_agent") @db.Text
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ════════════════════════════════════════════════════════════
// MODEL: AuditLog (Denetim Kaydı)
// ════════════════════════════════════════════════════════════
// Sistemdeki TÜM önemli işlemleri kaydeder.
// Kim, ne, ne zaman, hangi IP'den yaptı.
// ════════════════════════════════════════════════════════════
model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String?     @map("tenant_id")
  userId     String?     @map("user_id")
  action     AuditAction
  resource   String      @db.VarChar(100) // tablo adı
  resourceId String?     @map("resource_id") // etkilenen kaydın ID'si
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  userAgent  String?     @map("user_agent") @db.Text
  metadata   Json?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ════════════════════════════════════════════════════════════
// MODEL: Project (Proje / Şantiye)
// ════════════════════════════════════════════════════════════
// İnşaat projesi - ana iş birimi.
// Her proje bir tenant'a aittir. Taşeronlar, hakediş, stok, 
// personel hep bu projeye bağlanır.
// ════════════════════════════════════════════════════════════
model Project {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  code        String        @db.VarChar(50) // Proje kodu (örn: PRJ-2026-001)
  name        String        @db.VarChar(255)
  description String?       @db.Text
  status      ProjectStatus @default(PLANNING)

  // Lokasyon
  address  String? @db.Text
  city     String? @db.VarChar(100)
  district String? @db.VarChar(100)

  // Müşteri/İşveren
  clientName      String? @map("client_name") @db.VarChar(255)
  clientTaxNumber String? @map("client_tax_number") @db.VarChar(20)
  clientPhone     String? @map("client_phone") @db.VarChar(20)
  clientEmail     String? @map("client_email") @db.VarChar(255)

  // Bütçe ve süre
  contractAmount Decimal?  @map("contract_amount") @db.Decimal(18, 2)
  currency       String    @default("TRY") @db.VarChar(3)
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  actualEndDate  DateTime? @map("actual_end_date") @db.Date

  // İlişkiler (ileride eklenecek: taseronlar, hakedisler, stok, vs.)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  progressPayments  ProgressPayment[]
  materialMovements MaterialMovement[]
  timesheetEntries  TimesheetEntry[] // ← BU YENİ

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@unique([tenantId, code]) // Aynı tenant içinde proje kodu eşsiz
  @@index([tenantId])
  @@index([status])
  @@index([deletedAt])
  @@index([startDate])
  @@map("projects")
}

enum ProjectStatus {
  PLANNING // Planlama aşamasında
  ACTIVE // Aktif - inşaat devam ediyor
  ON_HOLD // Beklemede / durduruldu
  COMPLETED // Tamamlandı
  CANCELLED // İptal edildi

  @@map("project_status")
}

// ════════════════════════════════════════════════════════════
// MODEL: Subcontractor (Taşeron / Alt Yüklenici)
// ════════════════════════════════════════════════════════════
// İnşaat projelerinde işin bir kısmını yapan alt firmalar.
// Örnek: betoncular, kalıpçılar, demirciler, elektrikçiler, vs.
// İleride hakediş, sözleşme ve performans takibi için kullanılacak.
// ════════════════════════════════════════════════════════════
model Subcontractor {
  id       String                @id @default(cuid())
  tenantId String                @map("tenant_id")
  code     String                @db.VarChar(50)
  name     String                @db.VarChar(255) // Firma adı
  category SubcontractorCategory @default(OTHER)
  status   SubcontractorStatus   @default(ACTIVE)

  // İletişim
  contactPerson String? @map("contact_person") @db.VarChar(255)
  phone         String? @db.VarChar(20)
  email         String? @db.VarChar(255)

  // Adres
  address  String? @db.Text
  city     String? @db.VarChar(100)
  district String? @db.VarChar(100)

  // Resmi bilgiler
  taxNumber     String? @map("tax_number") @db.VarChar(20)
  taxOffice     String? @map("tax_office") @db.VarChar(100)
  tradeRegistry String? @map("trade_registry") @db.VarChar(50)
  iban          String? @db.VarChar(34)

  // Notlar
  notes String? @db.Text

  // İlişkiler
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  progressPayments ProgressPayment[]
  employees        SubcontractorEmployee[] // ← BU YENİ
  timesheetEntries TimesheetEntry[] // ← BU YENİ

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([category])
  @@index([status])
  @@index([deletedAt])
  @@map("subcontractors")
}

enum SubcontractorCategory {
  EXCAVATION // Hafriyat
  CONCRETE // Beton
  FORMWORK // Kalıp
  REBAR // Demir donatı
  MASONRY // Duvarcılık
  PLASTER // Sıva
  PAINT // Boya
  TILE // Fayans/seramik
  ELECTRICAL // Elektrik
  PLUMBING // Sıhhi tesisat
  HVAC // Mekanik
  CARPENTRY // Doğrama
  ROOFING // Çatı
  INSULATION // Yalıtım
  LANDSCAPING // Peyzaj
  CLEANING // Temizlik
  OTHER // Diğer

  @@map("subcontractor_category")
}

enum SubcontractorStatus {
  ACTIVE // Aktif çalışıyor
  INACTIVE // Pasif (geçici)
  BLACKLISTED // Kara liste
  ARCHIVED // Arşivlendi

  @@map("subcontractor_status")
}

// ════════════════════════════════════════════════════════════
// MODEL: ProgressPayment (Hakediş)
// ════════════════════════════════════════════════════════════
// Bir taşeronun bir projede yaptığı işin parasal karşılığı.
// İnşaat ERP'sinin finansal omurgası. Dönem bazlı (aylık genelde),
// onay süreciyle takip edilir: TASLAK → SUNULDU → ONAYLI → ÖDENDİ
// ════════════════════════════════════════════════════════════
model ProgressPayment {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  code     String @db.VarChar(50) // HKD-2026-001

  // İlişkiler (FK)
  projectId       String @map("project_id")
  subcontractorId String @map("subcontractor_id")

  // Dönem (genelde aylık: 2026-05)
  period String @db.VarChar(7) // YYYY-MM format

  // Finansal
  amount      Decimal @db.Decimal(18, 2) // KDV hariç tutar
  taxRate     Decimal @default(20) @map("tax_rate") @db.Decimal(5, 2) // KDV oranı %
  taxAmount   Decimal @map("tax_amount") @db.Decimal(18, 2) // KDV tutarı
  totalAmount Decimal @map("total_amount") @db.Decimal(18, 2) // Toplam (KDV dahil)
  currency    String  @default("TRY") @db.VarChar(3)

  // Durum
  status PaymentStatus @default(DRAFT)

  // İçerik
  description String? @db.Text // Yapılan işin açıklaması
  notes       String? @db.Text

  // Tarihler
  issuedAt      DateTime? @map("issued_at") // Hakediş düzenleme tarihi
  approvedAt    DateTime? @map("approved_at") // Onay tarihi
  paidAt        DateTime? @map("paid_at") // Ödeme tarihi
  paymentMethod String?   @map("payment_method") @db.VarChar(50) // Havale, Çek, Nakit
  paymentRef    String?   @map("payment_ref") @db.VarChar(255) // İşlem referansı

  // İlişkiler
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)

  // Audit
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  createdBy  String?   @map("created_by")
  updatedBy  String?   @map("updated_by")
  approvedBy String?   @map("approved_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([projectId])
  @@index([subcontractorId])
  @@index([status])
  @@index([period])
  @@index([deletedAt])
  @@map("progress_payments")
}

enum PaymentStatus {
  DRAFT // Taslak
  SUBMITTED // Sunuldu (onaya gönderildi)
  APPROVED // Onaylandı (ödemeye hazır)
  PAID // Ödendi
  REJECTED // Reddedildi
  CANCELLED // İptal

  @@map("payment_status")
}

// ════════════════════════════════════════════════════════════
// MODEL: Material (Malzeme Kataloğu)
// ════════════════════════════════════════════════════════════
// İnşaatta kullanılan malzemelerin master listesi.
// Çimento, demir, kum, fayans gibi tekrar tekrar alınan kalemler.
// currentStock değeri, MaterialMovement'lardan otomatik güncellenir.
// ════════════════════════════════════════════════════════════
model Material {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  code        String           @db.VarChar(50) // MAT-001
  name        String           @db.VarChar(255)
  category    MaterialCategory @default(OTHER)
  unit        MaterialUnit     @default(PIECE) // birim
  description String?          @db.Text

  // Stok bilgileri (otomatik güncellenir)
  currentStock      Decimal  @default(0) @map("current_stock") @db.Decimal(18, 4)
  minStock          Decimal  @default(0) @map("min_stock") @db.Decimal(18, 4)
  avgPrice          Decimal  @default(0) @map("avg_price") @db.Decimal(18, 4)
  lastPurchasePrice Decimal? @map("last_purchase_price") @db.Decimal(18, 4)
  currency          String   @default("TRY") @db.VarChar(3)

  // Notlar
  notes String? @db.Text

  // İlişkiler
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movements MaterialMovement[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([category])
  @@index([deletedAt])
  @@map("materials")
}

// ════════════════════════════════════════════════════════════
// MODEL: MaterialMovement (Stok Hareketi)
// ════════════════════════════════════════════════════════════
// Her giriş/çıkış kayıt altında. Material.currentStock buradan hesaplanır.
// IN = Satın alma, depo girişi
// OUT = Şantiyeye sevk, kullanım, sarfiyat
// ════════════════════════════════════════════════════════════
model MaterialMovement {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  materialId String  @map("material_id")
  projectId  String? @map("project_id") // OUT için zorunlu olabilir

  type       MovementType
  quantity   Decimal      @db.Decimal(18, 4)
  unitPrice  Decimal?     @map("unit_price") @db.Decimal(18, 4) // IN için zorunlu
  totalPrice Decimal?     @map("total_price") @db.Decimal(18, 4)
  currency   String       @default("TRY") @db.VarChar(3)

  // Tarih + Tedarikçi
  date      DateTime
  supplier  String?  @db.VarChar(255) // IN için (kimden alındı)
  invoiceNo String?  @map("invoice_no") @db.VarChar(100)

  // Notlar
  notes String? @db.Text

  // İlişkiler
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Restrict)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: Restrict)

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([tenantId])
  @@index([materialId])
  @@index([projectId])
  @@index([type])
  @@index([date])
  @@index([deletedAt])
  @@map("material_movements")
}

enum MaterialCategory {
  CEMENT // Çimento
  AGGREGATE // Agrega (kum, çakıl)
  STEEL // Demir/çelik
  TIMBER // Kereste
  BRICK_BLOCK // Tuğla, briket
  TILE_CERAMIC // Fayans, seramik
  PAINT_CHEMICAL // Boya, kimyasal
  ELECTRICAL // Elektrik malzemesi
  PLUMBING // Sıhhi tesisat malzemesi
  HVAC // Mekanik malzeme
  INSULATION // Yalıtım
  ADHESIVE // Yapıştırıcı, harç
  HARDWARE // Hırdavat
  TOOLS // Aletler
  SAFETY // İş güvenliği
  OTHER // Diğer

  @@map("material_category")
}

enum MaterialUnit {
  PIECE // Adet
  KG // Kilogram
  TON // Ton
  M // Metre
  M2 // Metrekare
  M3 // Metreküp
  LITER // Litre
  PACKAGE // Paket / Çuval
  BOX // Kutu
  ROLL // Rulo

  @@map("material_unit")
}

enum MovementType {
  IN // Stok girişi (satın alma)
  OUT // Stok çıkışı (kullanım/sevk)
  ADJUSTMENT // Düzeltme (sayım farkı)

  @@map("movement_type")
}

// ════════════════════════════════════════════════════════════
// MODEL: Contact (Cari Hesap)
// ════════════════════════════════════════════════════════════
// Firmanın çalıştığı tüm dış paydaşlar:
// - Tedarikçi: bizim aldığımız (çimento, demir satan firma)
// - Müşteri: bizim sattığımız (proje sahibi, alıcı)
// - Çift yönlü: hem alıcı hem satıcı (yaygın)
// Cari hesap bakiyesi: + = bize borçlu, - = biz borçluyuz
// (Cari Hareket tablosu sonraki sprint'te eklenecek)
// ════════════════════════════════════════════════════════════
model Contact {
  id       String        @id @default(cuid())
  tenantId String        @map("tenant_id")
  code     String        @db.VarChar(50) // CR-001
  name     String        @db.VarChar(255) // Firma/Kişi adı
  type     ContactType   @default(SUPPLIER)
  status   ContactStatus @default(ACTIVE)

  // İletişim
  contactPerson String? @map("contact_person") @db.VarChar(255)
  phone         String? @db.VarChar(20)
  email         String? @db.VarChar(255)
  website       String? @db.VarChar(255)

  // Adres
  address  String? @db.Text
  city     String? @db.VarChar(100)
  district String? @db.VarChar(100)
  country  String? @default("Türkiye") @db.VarChar(100)

  // Resmi
  taxNumber     String? @map("tax_number") @db.VarChar(20)
  taxOffice     String? @map("tax_office") @db.VarChar(100)
  tradeRegistry String? @map("trade_registry") @db.VarChar(50)
  iban          String? @db.VarChar(34)
  bankName      String? @map("bank_name") @db.VarChar(100)

  // Cari ayarlar
  paymentTerms Int?     @map("payment_terms") // Vade gün (örn: 30, 60)
  creditLimit  Decimal? @map("credit_limit") @db.Decimal(18, 2) // Müşteri için kredi limiti
  currency     String   @default("TRY") @db.VarChar(3)

  // Bakiye (Cari Hareket tablosu sonra gelecek, şimdilik 0)
  // İleride cari hareket eklendiğinde otomatik hesaplanacak
  currentBalance Decimal @default(0) @map("current_balance") @db.Decimal(18, 2)

  // Notlar
  notes String? @db.Text

  // İlişkiler
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions ContactTransaction[]
  cheques      Cheque[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([taxNumber])
  @@index([deletedAt])
  @@map("contacts")
}

enum ContactType {
  SUPPLIER // Tedarikçi
  CUSTOMER // Müşteri (mal sahibi)
  BOTH // Hem tedarikçi hem müşteri
  BANK // Banka
  GOVERNMENT // Vergi dairesi, SGK, vs.
  OTHER // Diğer

  @@map("contact_type")
}

enum ContactStatus {
  ACTIVE // Aktif çalışıyor
  INACTIVE // Pasif
  BLACKLISTED // Kara liste
  ARCHIVED // Arşivlendi

  @@map("contact_status")
}

// ════════════════════════════════════════════════════════════
// MODEL: ContactTransaction (Cari Hareket)
// ════════════════════════════════════════════════════════════
// Bir carinin tüm finansal hareketleri:
// - BORC: Bizim ona borçlandığımız (örn: malzeme aldık)
// - ALACAK: Onun bize borçlandığı (örn: müşteriye iş yaptık)
// - ODEME: Bizim ona ödediğimiz (cari borcumuz azalır)
// - TAHSILAT: Ondan tahsil ettiğimiz (cari alacağımız azalır)
//
// Bakiye mantığı (Contact.currentBalance):
//   + (pozitif) = Cari bize borçlu (alacaklıyız)
//   - (negatif) = Biz cariye borçluyuz
//
// Her hareket sonrası Contact.currentBalance otomatik güncellenir.
// ════════════════════════════════════════════════════════════
model ContactTransaction {
  id        String @id @default(cuid())
  tenantId  String @map("tenant_id")
  contactId String @map("contact_id")

  type     TransactionType
  amount   Decimal         @db.Decimal(18, 2)
  currency String          @default("TRY") @db.VarChar(3)

  // Tarih + Belge
  date        DateTime
  documentNo  String?  @map("document_no") @db.VarChar(100) // Fatura no, dekont no, vs.
  description String?  @db.Text

  // Ödeme/Tahsilat detayları
  paymentMethod String? @map("payment_method") @db.VarChar(50)
  bankReference String? @map("bank_reference") @db.VarChar(255)

  // Bakiye (bu hareketten sonraki bakiye - audit için)
  balanceAfter Decimal @map("balance_after") @db.Decimal(18, 2)

  // İlişkiler
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([tenantId])
  @@index([contactId])
  @@index([type])
  @@index([date])
  @@index([deletedAt])
  @@map("contact_transactions")
}

enum TransactionType {
  DEBT // BORÇ (biz cariye borçlu hale geldik — bakiye azalır)
  CREDIT // ALACAK (cari bize borçlu hale geldi — bakiye artar)
  PAYMENT // ÖDEME (biz cariye ödedik — bakiye artar, borcumuz azalır)
  COLLECTION // TAHSİLAT (cariden tahsil ettik — bakiye azalır, alacağımız azalır)

  @@map("transaction_type")
}

// ════════════════════════════════════════════════════════════
// MODEL: Cheque (Çek / Senet)
// ════════════════════════════════════════════════════════════
// Hem çek hem senet aynı tabloda (kind alanı ile ayrım)
//
// GELEN ÇEK/SENET (INCOMING):
//   - Müşteriden tahsilat olarak aldık
//   - Vadesinde bankada tahsil edilecek
//
// VERİLEN ÇEK/SENET (OUTGOING):
//   - Tedarikçiye ödeme olarak verdik
//   - Vadesinde bankamızdan çekilecek
// ════════════════════════════════════════════════════════════
model Cheque {
  id        String @id @default(cuid())
  tenantId  String @map("tenant_id")
  contactId String @map("contact_id")

  kind      ChequeKind // ÇEK veya SENET
  direction ChequeDirection // GELEN veya VERILEN

  // Numara + Banka
  chequeNo   String  @map("cheque_no") @db.VarChar(50) // çek no veya senet no
  bankName   String? @map("bank_name") @db.VarChar(100)
  bankBranch String? @map("bank_branch") @db.VarChar(100)
  drawer     String? @db.VarChar(255) // Keşideci (çek sahibi)

  // Finansal
  amount   Decimal @db.Decimal(18, 2)
  currency String  @default("TRY") @db.VarChar(3)

  // Tarihler
  issueDate DateTime @map("issue_date") // Düzenleme/keşide tarihi
  dueDate   DateTime @map("due_date") // Vade tarihi (KRİTİK)

  // Durum
  status     ChequeStatus @default(PORTFOLIO)
  statusDate DateTime?    @map("status_date") // Son durum değişimi
  statusNote String?      @map("status_note") @db.Text

  // Açıklama
  description String? @db.Text

  // İlişkiler
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([tenantId])
  @@index([contactId])
  @@index([kind])
  @@index([direction])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("cheques")
}

enum ChequeKind {
  CHEQUE // Çek
  PROMISSORY_NOTE // Senet

  @@map("cheque_kind")
}

enum ChequeDirection {
  INCOMING // Gelen (müşteriden, portföyde)
  OUTGOING // Verilen (tedarikçiye, tedavülde)

  @@map("cheque_direction")
}

enum ChequeStatus {
  PORTFOLIO // Portföyde (gelen için: tahsil bekleniyor / verilen için: vadesi yaklaşıyor)
  ENDORSED // Ciro edildi (başka bir cariye devredildi)
  DEPOSITED // Bankaya yatırıldı (gelen için)
  COLLECTED // Tahsil edildi (gelen için: para hesaba geçti)
  PAID // Ödendi (verilen için: bankamızdan çıktı)
  BOUNCED // Karşılıksız çıktı
  CANCELLED // İptal

  @@map("cheque_status")
}

// ════════════════════════════════════════════════════════════
// MODEL: SubcontractorEmployee (Taşeron İşçisi / Ekip Üyesi)
// ════════════════════════════════════════════════════════════
// Her taşerona bağlı işçi/usta listesi.
// Puantaj kayıtlarında her işçi ayrı satır olarak girilir.
// ════════════════════════════════════════════════════════════
model SubcontractorEmployee {
  id              String @id @default(cuid())
  tenantId        String @map("tenant_id")
  subcontractorId String @map("subcontractor_id")

  name  String  @db.VarChar(255)
  tcNo  String? @map("tc_no") @db.VarChar(11)
  phone String? @db.VarChar(20)

  specialty EmployeeSpecialty @default(LABORER)
  role      String?           @db.VarChar(100) // Serbest metin (Demirci, Sıvacı, vs.)
  dailyWage Decimal           @default(0) @map("daily_wage") @db.Decimal(18, 2)
  currency  String            @default("TRY") @db.VarChar(3)

  startDate DateTime?      @map("start_date")
  endDate   DateTime?      @map("end_date")
  status    EmployeeStatus @default(ACTIVE)

  notes String? @db.Text

  // İlişkiler
  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subcontractor    Subcontractor          @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  timesheetDetails TimesheetEntryDetail[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([tenantId])
  @@index([subcontractorId])
  @@index([status])
  @@index([deletedAt])
  @@map("subcontractor_employees")
}

// ════════════════════════════════════════════════════════════
// MODEL: TimesheetEntry (Günlük Puantaj Başlığı)
// ════════════════════════════════════════════════════════════
// Bir taşeronun, bir günde, bir projedeki çalışmasını temsil eder.
// Detaylar (hangi işçi kaç saat) TimesheetEntryDetail tablosunda.
// ════════════════════════════════════════════════════════════
model TimesheetEntry {
  id              String @id @default(cuid())
  tenantId        String @map("tenant_id")
  subcontractorId String @map("subcontractor_id")
  projectId       String @map("project_id")

  date            DateTime // Puantaj tarihi
  workDescription String?  @map("work_description") @db.Text
  approvedBy      String?  @map("approved_by") @db.VarChar(255)

  status TimesheetStatus @default(DRAFT)

  // Otomatik hesaplananlar (detaylardan)
  totalAmount   Decimal @default(0) @map("total_amount") @db.Decimal(18, 2)
  employeeCount Int     @default(0) @map("employee_count")
  totalHours    Decimal @default(0) @map("total_hours") @db.Decimal(10, 2)
  currency      String  @default("TRY") @db.VarChar(3)

  notes String? @db.Text

  // İlişkiler
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subcontractor Subcontractor          @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)
  project       Project                @relation(fields: [projectId], references: [id], onDelete: Restrict)
  details       TimesheetEntryDetail[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([tenantId])
  @@index([subcontractorId])
  @@index([projectId])
  @@index([date])
  @@index([status])
  @@index([deletedAt])
  @@map("timesheet_entries")
}

// ════════════════════════════════════════════════════════════
// MODEL: TimesheetEntryDetail (İşçi Detay Satırı)
// ════════════════════════════════════════════════════════════
// Her TimesheetEntry'nin altında, her işçi için bir detay satırı.
// Saat, ücret, mesai bilgileri burada.
// ════════════════════════════════════════════════════════════
model TimesheetEntryDetail {
  id               String @id @default(cuid())
  tenantId         String @map("tenant_id")
  timesheetEntryId String @map("timesheet_entry_id")
  employeeId       String @map("employee_id")

  // Çalışma
  absent             Boolean @default(false) // Gelmedi
  hoursWorked        Decimal @default(8) @map("hours_worked") @db.Decimal(5, 2)
  dailyWage          Decimal @map("daily_wage") @db.Decimal(18, 2) // Snapshot - o günkü ücret
  overtimeHours      Decimal @default(0) @map("overtime_hours") @db.Decimal(5, 2)
  overtimeMultiplier Decimal @default(1.5) @map("overtime_multiplier") @db.Decimal(3, 2)

  // Hesap (otomatik)
  totalEarning Decimal @default(0) @map("total_earning") @db.Decimal(18, 2)

  notes String? @db.Text

  // İlişkiler
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timesheetEntry TimesheetEntry        @relation(fields: [timesheetEntryId], references: [id], onDelete: Cascade)
  employee       SubcontractorEmployee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([timesheetEntryId])
  @@index([employeeId])
  @@map("timesheet_entry_details")
}

// ════════════════════════════════════════════════════════════
// ENUMS
// ════════════════════════════════════════════════════════════

enum EmployeeSpecialty {
  FOREMAN // Ustabaşı
  MASTER // Usta
  APPRENTICE // Çırak
  LABORER // Düz işçi
  OPERATOR // Operatör (makine)
  DRIVER // Şoför
  TECHNICIAN // Teknisyen
  ENGINEER // Mühendis
  OTHER // Diğer

  @@map("employee_specialty")
}

enum EmployeeStatus {
  ACTIVE // Aktif çalışıyor
  INACTIVE // Geçici durdurma
  TERMINATED // İşten ayrıldı
  ARCHIVED // Arşivlendi

  @@map("employee_status")
}

enum TimesheetStatus {
  DRAFT // Taslak (düzenleme aşaması)
  APPROVED // Onaylandı (proje müdürü tarafından)
  PAID // Ödendi (hakedişe yansıdı)
  CANCELLED // İptal

  @@map("timesheet_status")
}
