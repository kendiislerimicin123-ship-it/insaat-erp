// ════════════════════════════════════════════════════════════
// İnşaat ERP - Prisma Schema
// ════════════════════════════════════════════════════════════
// Bu dosya veri modelinin TEK kaynağıdır.
// Değişiklik sonrası: npm run db:migrate çalıştır
// ════════════════════════════════════════════════════════════

// ─────────────────────────────────
// Generator: Prisma Client (TS API)
// ─────────────────────────────────
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

// ─────────────────────────────────
// Datasource: PostgreSQL
// ─────────────────────────────────
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════
// ENUM'LAR
// ════════════════════════════════════════════════════════════

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION

  @@map("user_status")
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  TRIAL
  EXPIRED
  SUSPENDED

  @@map("tenant_status")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  PASSWORD_RESET
  PERMISSION_GRANT
  PERMISSION_REVOKE
  ROLE_ASSIGN
  ROLE_REVOKE

  @@map("audit_action")
}

// ════════════════════════════════════════════════════════════
// MODEL: Tenant (Firma / Şirket)
// ════════════════════════════════════════════════════════════
// Multi-tenant mimarinin temeli. Her veri bir tenant'a aittir.
// ════════════════════════════════════════════════════════════
model Tenant {
  id        String       @id @default(cuid())
  name      String       @db.VarChar(255)
  slug      String       @unique @db.VarChar(100)
  taxNumber String?      @unique @map("tax_number") @db.VarChar(20)
  email     String?      @db.VarChar(255)
  phone     String?      @db.VarChar(20)
  address   String?      @db.Text
  city      String?      @db.VarChar(100)
  status    TenantStatus @default(TRIAL)

  // İlişkiler
  users                  User[]
  roles                  Role[]
  auditLogs              AuditLog[]
  projects               Project[]
  subcontractors         Subcontractor[]
  progressPayments       ProgressPayment[]
  materials              Material[]
  materialMovements      MaterialMovement[]
  contacts               Contact[]
  contactTransactions    ContactTransaction[]
  cheques                Cheque[]
  subcontractorEmployees SubcontractorEmployee[]
  timesheetEntries       TimesheetEntry[]
  timesheetEntryDetails  TimesheetEntryDetail[]

  // Audit alanları
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("tenants")
}

// ════════════════════════════════════════════════════════════
// MODEL: User (Kullanıcı)
// ════════════════════════════════════════════════════════════
model User {
  id              String     @id @default(cuid())
  tenantId        String     @map("tenant_id")
  email           String     @db.VarChar(255)
  password        String     @db.VarChar(255) // bcrypt hash
  firstName       String     @map("first_name") @db.VarChar(100)
  lastName        String     @map("last_name") @db.VarChar(100)
  phone           String?    @db.VarChar(20)
  avatar          String?    @db.Text
  status          UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  lastLoginIp     String?    @map("last_login_ip") @db.VarChar(45)

  // İlişkiler
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  // Audit alanları
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  // Multi-tenant: Aynı email birden fazla tenant'ta olabilir
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

// ════════════════════════════════════════════════════════════
// MODEL: Role (Rol)
// ════════════════════════════════════════════════════════════
model Role {
  id          String  @id @default(cuid())
  tenantId    String? @map("tenant_id") // null = sistem geneli
  name        String  @db.VarChar(100)
  slug        String  @db.VarChar(100)
  description String? @db.Text
  isSystem    Boolean @default(false) @map("is_system")

  // İlişkiler
  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  // Audit alanları
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([slug])
  @@index([deletedAt])
  @@map("roles")
}

// ════════════════════════════════════════════════════════════
// MODEL: Permission (İzin)
// ════════════════════════════════════════════════════════════
model Permission {
  id          String  @id @default(cuid())
  resource    String  @db.VarChar(100)
  action      String  @db.VarChar(50)
  description String? @db.Text

  // İlişkiler
  rolePermissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

// ════════════════════════════════════════════════════════════
// MODEL: UserRole (M2M: User <-> Role)
// ════════════════════════════════════════════════════════════
model UserRole {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ════════════════════════════════════════════════════════════
// MODEL: RolePermission (M2M: Role <-> Permission)
// ════════════════════════════════════════════════════════════
model RolePermission {
  id           String   @id @default(cuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  grantedAt    DateTime @default(now()) @map("granted_at")
  grantedBy    String?  @map("granted_by")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ════════════════════════════════════════════════════════════
// MODEL: RefreshToken (JWT Refresh Token Yönetimi)
// ════════════════════════════════════════════════════════════
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  token     String    @unique @db.VarChar(500)
  userAgent String?   @map("user_agent") @db.Text
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ════════════════════════════════════════════════════════════
// MODEL: AuditLog (Denetim Kaydı)
// ════════════════════════════════════════════════════════════
model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String?     @map("tenant_id")
  userId     String?     @map("user_id")
  action     AuditAction
  resource   String      @db.VarChar(100)
  resourceId String?     @map("resource_id")
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  userAgent  String?     @map("user_agent") @db.Text
  metadata   Json?

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

// ════════════════════════════════════════════════════════════
// MODEL: Project (Proje / Şantiye)
// ════════════════════════════════════════════════════════════
model Project {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  code        String        @db.VarChar(50)
  name        String        @db.VarChar(255)
  description String?       @db.Text
  status      ProjectStatus @default(PLANNING)

  // Lokasyon
  address  String? @db.Text
  city     String? @db.VarChar(100)
  district String? @db.VarChar(100)

  // Müşteri/İşveren
  clientName      String? @map("client_name") @db.VarChar(255)
  clientTaxNumber String? @map("client_tax_number") @db.VarChar(20)
  clientPhone     String? @map("client_phone") @db.VarChar(20)
  clientEmail     String? @map("client_email") @db.VarChar(255)

  // Bütçe ve süre
  contractAmount Decimal?  @map("contract_amount") @db.Decimal(18, 2)
  currency       String    @default("TRY") @db.VarChar(3)
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  actualEndDate  DateTime? @map("actual_end_date") @db.Date

  // İlişkiler
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  progressPayments  ProgressPayment[]
  materialMovements MaterialMovement[]
  timesheetEntries  TimesheetEntry[]
  expenses          Expense[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@index([deletedAt])
  @@index([startDate])
  @@map("projects")
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED

  @@map("project_status")
}

// ════════════════════════════════════════════════════════════
// MODEL: Subcontractor (Taşeron / Alt Yüklenici)
// ════════════════════════════════════════════════════════════
model Subcontractor {
  id       String                @id @default(cuid())
  tenantId String                @map("tenant_id")
  code     String                @db.VarChar(50)
  name     String                @db.VarChar(255)
  category SubcontractorCategory @default(OTHER)
  status   SubcontractorStatus   @default(ACTIVE)

  // İletişim
  contactPerson String? @map("contact_person") @db.VarChar(255)
  phone         String? @db.VarChar(20)
  email         String? @db.VarChar(255)

  // Adres
  address  String? @db.Text
  city     String? @db.VarChar(100)
  district String? @db.VarChar(100)

  // Resmi bilgiler
  taxNumber     String? @map("tax_number") @db.VarChar(20)
  taxOffice     String? @map("tax_office") @db.VarChar(100)
  tradeRegistry String? @map("trade_registry") @db.VarChar(50)
  iban          String? @db.VarChar(34)

  // Notlar
  notes String? @db.Text

  // İlişkiler
  tenant           Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  progressPayments ProgressPayment[]
  employees        SubcontractorEmployee[]
  timesheetEntries TimesheetEntry[]
  expenses         Expense[]
  cheques          Cheque[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([category])
  @@index([status])
  @@index([deletedAt])
  @@map("subcontractors")
}

enum SubcontractorCategory {
  EXCAVATION
  CONCRETE
  FORMWORK
  REBAR
  MASONRY
  PLASTER
  PAINT
  TILE
  ELECTRICAL
  PLUMBING
  HVAC
  CARPENTRY
  ROOFING
  INSULATION
  LANDSCAPING
  CLEANING
  OTHER

  @@map("subcontractor_category")
}

enum SubcontractorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
  ARCHIVED

  @@map("subcontractor_status")
}

// ════════════════════════════════════════════════════════════
// MODEL: ProgressPayment (Hakediş)
// ════════════════════════════════════════════════════════════
model ProgressPayment {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  code     String @db.VarChar(50)

  // İlişkiler (FK)
  projectId       String @map("project_id")
  subcontractorId String @map("subcontractor_id")

  // Dönem
  period String @db.VarChar(7)

  // Finansal
  amount      Decimal @db.Decimal(18, 2)
  taxRate     Decimal @default(20) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount   Decimal @map("tax_amount") @db.Decimal(18, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(18, 2)
  currency    String  @default("TRY") @db.VarChar(3)

  // Durum
  status PaymentStatus @default(DRAFT)

  // İçerik
  description String? @db.Text
  notes       String? @db.Text

  // Tarihler
  issuedAt      DateTime?      @map("issued_at")
  approvedAt    DateTime?      @map("approved_at")
  paidAt        DateTime?      @map("paid_at")
  paymentMethod PaymentMethod? @map("payment_method")
  paymentRef    String?        @map("payment_ref") @db.VarChar(255)

  // İlişkiler
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)

  // Audit
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")
  createdBy  String?   @map("created_by")
  updatedBy  String?   @map("updated_by")
  approvedBy String?   @map("approved_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([projectId])
  @@index([subcontractorId])
  @@index([status])
  @@index([period])
  @@index([deletedAt])
  @@map("progress_payments")
}

enum PaymentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  REJECTED
  CANCELLED

  @@map("payment_status")
}

// ════════════════════════════════════════════════════════════
// MODEL: Material (Malzeme Kataloğu)
// ════════════════════════════════════════════════════════════
model Material {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  code        String           @db.VarChar(50)
  name        String           @db.VarChar(255)
  category    MaterialCategory @default(OTHER)
  unit        MaterialUnit     @default(PIECE)
  description String?          @db.Text

  // Stok bilgileri
  currentStock      Decimal  @default(0) @map("current_stock") @db.Decimal(18, 4)
  minStock          Decimal  @default(0) @map("min_stock") @db.Decimal(18, 4)
  avgPrice          Decimal  @default(0) @map("avg_price") @db.Decimal(18, 4)
  lastPurchasePrice Decimal? @map("last_purchase_price") @db.Decimal(18, 4)
  currency          String   @default("TRY") @db.VarChar(3)

  notes String? @db.Text

  // İlişkiler
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movements MaterialMovement[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([category])
  @@index([deletedAt])
  @@map("materials")
}

// ════════════════════════════════════════════════════════════
// MODEL: MaterialMovement (Stok Hareketi)
// ════════════════════════════════════════════════════════════
model MaterialMovement {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  materialId String  @map("material_id")
  projectId  String? @map("project_id")

  type       MovementType
  quantity   Decimal      @db.Decimal(18, 4)
  unitPrice  Decimal?     @map("unit_price") @db.Decimal(18, 4)
  totalPrice Decimal?     @map("total_price") @db.Decimal(18, 4)
  currency   String       @default("TRY") @db.VarChar(3)

  date      DateTime
  supplier  String?  @db.VarChar(255)
  invoiceNo String?  @map("invoice_no") @db.VarChar(100)

  notes String? @db.Text

  // İlişkiler
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Restrict)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: Restrict)

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([tenantId])
  @@index([materialId])
  @@index([projectId])
  @@index([type])
  @@index([date])
  @@index([deletedAt])
  @@map("material_movements")
}

enum MaterialCategory {
  CEMENT
  AGGREGATE
  STEEL
  TIMBER
  BRICK_BLOCK
  TILE_CERAMIC
  PAINT_CHEMICAL
  ELECTRICAL
  PLUMBING
  HVAC
  INSULATION
  ADHESIVE
  HARDWARE
  TOOLS
  SAFETY
  OTHER

  @@map("material_category")
}

enum MaterialUnit {
  PIECE
  KG
  TON
  M
  M2
  M3
  LITER
  PACKAGE
  BOX
  ROLL

  @@map("material_unit")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT

  @@map("movement_type")
}

// ════════════════════════════════════════════════════════════
// MODEL: Contact (Cari Hesap)
// ════════════════════════════════════════════════════════════
model Contact {
  id       String        @id @default(cuid())
  tenantId String        @map("tenant_id")
  code     String        @db.VarChar(50)
  name     String        @db.VarChar(255)
  type     ContactType   @default(SUPPLIER)
  status   ContactStatus @default(ACTIVE)

  // İletişim
  contactPerson String? @map("contact_person") @db.VarChar(255)
  phone         String? @db.VarChar(20)
  email         String? @db.VarChar(255)
  website       String? @db.VarChar(255)

  // Adres
  address  String? @db.Text
  city     String? @db.VarChar(100)
  district String? @db.VarChar(100)
  country  String? @default("Türkiye") @db.VarChar(100)

  // Resmi
  taxNumber     String? @map("tax_number") @db.VarChar(20)
  taxOffice     String? @map("tax_office") @db.VarChar(100)
  tradeRegistry String? @map("trade_registry") @db.VarChar(50)
  iban          String? @db.VarChar(34)
  bankName      String? @map("bank_name") @db.VarChar(100)

  // Cari ayarlar
  paymentTerms Int?     @map("payment_terms")
  creditLimit  Decimal? @map("credit_limit") @db.Decimal(18, 2)
  currency     String   @default("TRY") @db.VarChar(3)

  // Bakiye
  currentBalance Decimal @default(0) @map("current_balance") @db.Decimal(18, 2)

  notes String? @db.Text

  // İlişkiler
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions ContactTransaction[]
  cheques      Cheque[]
  expenses     Expense[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([taxNumber])
  @@index([deletedAt])
  @@map("contacts")
}

enum ContactType {
  SUPPLIER
  CUSTOMER
  BOTH
  BANK
  GOVERNMENT
  OTHER

  @@map("contact_type")
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
  ARCHIVED

  @@map("contact_status")
}

// ════════════════════════════════════════════════════════════
// MODEL: ContactTransaction (Cari Hareket)
// ════════════════════════════════════════════════════════════
model ContactTransaction {
  id        String @id @default(cuid())
  tenantId  String @map("tenant_id")
  contactId String @map("contact_id")

  type     TransactionType
  amount   Decimal         @db.Decimal(18, 2)
  currency String          @default("TRY") @db.VarChar(3)

  // Tarih + Belge
  date        DateTime
  documentNo  String?  @map("document_no") @db.VarChar(100)
  description String?  @db.Text

  // Ödeme/Tahsilat detayları
  paymentMethod PaymentMethod? @map("payment_method")
  bankReference String? @map("bank_reference") @db.VarChar(255)

  // Bakiye
  balanceAfter Decimal @map("balance_after") @db.Decimal(18, 2)

  // İlişkiler
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([tenantId])
  @@index([contactId])
  @@index([type])
  @@index([date])
  @@index([deletedAt])
  @@map("contact_transactions")
}

enum TransactionType {
  DEBT
  CREDIT
  PAYMENT
  COLLECTION

  @@map("transaction_type")
}

// ════════════════════════════════════════════════════════════
// MODEL: Cheque (Çek / Senet)
// ════════════════════════════════════════════════════════════
// Hem çek hem senet aynı tabloda (kind alanı ile ayrım)
//
// GELEN ÇEK/SENET (INCOMING): Müşteriden tahsilat olarak aldık
// VERİLEN ÇEK/SENET (OUTGOING): Tedarikçi/Taşerona ödeme olarak verdik
//
// Bağlantı: ya contact'a ya da subcontractor'a (ikisinden biri)
// Source tracking: Otomatik mi manuel mi?
// ════════════════════════════════════════════════════════════
model Cheque {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")

  // Bağlantı: Cari VEYA Taşeron (en az biri dolu olmalı)
  contactId       String? @map("contact_id")
  subcontractorId String? @map("subcontractor_id")

  kind      ChequeKind
  direction ChequeDirection

  // Numara + Banka
  chequeNo   String  @map("cheque_no") @db.VarChar(50)
  bankName   String? @map("bank_name") @db.VarChar(100)
  bankBranch String? @map("bank_branch") @db.VarChar(100)
  drawer     String? @db.VarChar(255)

  // Finansal
  amount   Decimal @db.Decimal(18, 2)
  currency String  @default("TRY") @db.VarChar(3)

  // Tarihler
  issueDate DateTime @map("issue_date")
  dueDate   DateTime @map("due_date")

  // Durum
  status     ChequeStatus @default(PORTFOLIO)
  statusDate DateTime?    @map("status_date")
  statusNote String?      @map("status_note") @db.Text

  // Açıklama
  description String? @db.Text

  // ─── OTOMATİK / KAYNAK BİLGİSİ ───
  sourceType      ChequeSourceType @default(MANUAL) @map("source_type")
  sourceId        String?          @map("source_id")
  isAutoGenerated Boolean          @default(false) @map("is_auto_generated")

  // İlişkiler
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact       Contact?       @relation(fields: [contactId], references: [id], onDelete: Restrict)
  subcontractor Subcontractor? @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@unique([tenantId, sourceType, sourceId], name: "unique_cheque_source")
  @@index([tenantId])
  @@index([contactId])
  @@index([subcontractorId])
  @@index([kind])
  @@index([direction])
  @@index([status])
  @@index([dueDate])
  @@index([sourceType, sourceId])
  @@index([deletedAt])
  @@map("cheques")
}

enum ChequeKind {
  CHEQUE
  PROMISSORY_NOTE

  @@map("cheque_kind")
}

enum ChequeDirection {
  INCOMING
  OUTGOING

  @@map("cheque_direction")
}

enum ChequeStatus {
  PORTFOLIO
  ENDORSED
  DEPOSITED
  COLLECTED
  PAID
  BOUNCED
  CANCELLED

  @@map("cheque_status")
}

// Kaynak türü — otomatik çek kayıtları için
enum ChequeSourceType {
  MANUAL
  PROGRESS_PAYMENT
  CONTACT_TRANSACTION
  EXPENSE

  @@map("cheque_source_type")
}

// ════════════════════════════════════════════════════════════
// MODEL: SubcontractorEmployee (Taşeron İşçisi)
// ════════════════════════════════════════════════════════════
model SubcontractorEmployee {
  id              String @id @default(cuid())
  tenantId        String @map("tenant_id")
  subcontractorId String @map("subcontractor_id")

  name  String  @db.VarChar(255)
  tcNo  String? @map("tc_no") @db.VarChar(11)
  phone String? @db.VarChar(20)

  specialty EmployeeSpecialty @default(LABORER)
  role      String?           @db.VarChar(100)
  dailyWage Decimal           @default(0) @map("daily_wage") @db.Decimal(18, 2)
  currency  String            @default("TRY") @db.VarChar(3)

  startDate DateTime?      @map("start_date")
  endDate   DateTime?      @map("end_date")
  status    EmployeeStatus @default(ACTIVE)

  notes String? @db.Text

  // İlişkiler
  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subcontractor    Subcontractor          @relation(fields: [subcontractorId], references: [id], onDelete: Cascade)
  timesheetDetails TimesheetEntryDetail[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([tenantId])
  @@index([subcontractorId])
  @@index([status])
  @@index([deletedAt])
  @@map("subcontractor_employees")
}

// ════════════════════════════════════════════════════════════
// MODEL: TimesheetEntry (Günlük Puantaj Başlığı)
// ════════════════════════════════════════════════════════════
model TimesheetEntry {
  id              String @id @default(cuid())
  tenantId        String @map("tenant_id")
  subcontractorId String @map("subcontractor_id")
  projectId       String @map("project_id")

  date            DateTime
  workDescription String?  @map("work_description") @db.Text
  approvedBy      String?  @map("approved_by") @db.VarChar(255)

  status TimesheetStatus @default(DRAFT)

  // Otomatik hesaplananlar
  totalAmount   Decimal @default(0) @map("total_amount") @db.Decimal(18, 2)
  employeeCount Int     @default(0) @map("employee_count")
  totalHours    Decimal @default(0) @map("total_hours") @db.Decimal(10, 2)
  currency      String  @default("TRY") @db.VarChar(3)

  notes String? @db.Text

  // İlişkiler
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subcontractor Subcontractor          @relation(fields: [subcontractorId], references: [id], onDelete: Restrict)
  project       Project                @relation(fields: [projectId], references: [id], onDelete: Restrict)
  details       TimesheetEntryDetail[]

  // Audit
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")

  @@index([tenantId])
  @@index([subcontractorId])
  @@index([projectId])
  @@index([date])
  @@index([status])
  @@index([deletedAt])
  @@map("timesheet_entries")
}

// ════════════════════════════════════════════════════════════
// MODEL: TimesheetEntryDetail (İşçi Detay Satırı)
// ════════════════════════════════════════════════════════════
model TimesheetEntryDetail {
  id               String @id @default(cuid())
  tenantId         String @map("tenant_id")
  timesheetEntryId String @map("timesheet_entry_id")
  employeeId       String @map("employee_id")

  absent             Boolean @default(false)
  hoursWorked        Decimal @default(8) @map("hours_worked") @db.Decimal(5, 2)
  dailyWage          Decimal @map("daily_wage") @db.Decimal(18, 2)
  overtimeHours      Decimal @default(0) @map("overtime_hours") @db.Decimal(5, 2)
  overtimeMultiplier Decimal @default(1.5) @map("overtime_multiplier") @db.Decimal(3, 2)

  totalEarning Decimal @default(0) @map("total_earning") @db.Decimal(18, 2)

  notes String? @db.Text

  // İlişkiler
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timesheetEntry TimesheetEntry        @relation(fields: [timesheetEntryId], references: [id], onDelete: Cascade)
  employee       SubcontractorEmployee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([timesheetEntryId])
  @@index([employeeId])
  @@map("timesheet_entry_details")
}

enum EmployeeSpecialty {
  FOREMAN
  MASTER
  APPRENTICE
  LABORER
  OPERATOR
  DRIVER
  TECHNICIAN
  ENGINEER
  OTHER

  @@map("employee_specialty")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ARCHIVED

  @@map("employee_status")
}

enum TimesheetStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED

  @@map("timesheet_status")
}

// ════════════════════════════════════════════════════════════
// EXPENSE (Genel Gider Kaydı)
// ════════════════════════════════════════════════════════════

enum ExpenseCategory {
  // Manuel girilen kategoriler
  OFFICE
  VEHICLE
  PAYROLL_TAX
  EQUIPMENT
  UTILITIES
  PERMITS
  INSURANCE
  CONSULTING
  FOOD
  TRANSPORTATION
  COMMUNICATION
  ENTERTAINMENT
  OTHER

  // Otomatik oluşan kategoriler
  SUBCONTRACTOR
  LABOR
  MATERIAL_PURCHASE
  SUPPLIER_PAYMENT
}

enum ExpenseStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK
  CHEQUE
  CREDIT_CARD
  OTHER
}

enum ExpenseSourceType {
  MANUAL
  PROGRESS_PAYMENT
  TIMESHEET
  MATERIAL_MOVEMENT
  CONTACT_TRANSACTION
}

model Expense {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  code     String

  category ExpenseCategory
  status   ExpenseStatus   @default(CONFIRMED)

  amount      Decimal @db.Decimal(15, 2)
  vatRate     Decimal @default(0) @map("vat_rate") @db.Decimal(5, 2)
  vatAmount   Decimal @default(0) @map("vat_amount") @db.Decimal(15, 2)
  totalAmount Decimal @map("total_amount") @db.Decimal(15, 2)
  currency    String  @default("TRY")

  date        DateTime @db.Date
  description String
  notes       String?

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id])

  contactId String?  @map("contact_id")
  contact   Contact? @relation(fields: [contactId], references: [id])

  subcontractorId String?        @map("subcontractor_id")
  subcontractor   Subcontractor? @relation(fields: [subcontractorId], references: [id])

  invoiceNo String? @map("invoice_no")
  taxNumber String? @map("tax_number")

  paymentMethod PaymentMethod? @map("payment_method")
  paidAt        DateTime?      @map("paid_at")

  // Otomatik / kaynak
  sourceType      ExpenseSourceType @default(MANUAL) @map("source_type")
  sourceId        String?           @map("source_id")
  isAutoGenerated Boolean           @default(false) @map("is_auto_generated")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  createdBy String    @map("created_by")
  updatedBy String    @map("updated_by")

  @@unique([tenantId, sourceType, sourceId], name: "unique_source")
  @@index([tenantId, deletedAt])
  @@index([tenantId, code])
  @@index([projectId])
  @@index([contactId])
  @@index([subcontractorId])
  @@index([category])
  @@index([date])
  @@index([sourceType, sourceId])
  @@map("expenses")
}
